	macydnah/office (41ebef8)
*/ -}}

[manager]
show_hidden = true

{{- if .headless }}

[preview]
max_width = 512
max_height = 512
{{- end }}

{{- if (lookPath "office-textconv") }}
[plugin]

prepend_preloaders = [
    # Office Documents
    { mime = "application/openxmlformats-officedocument.*", run = "office-textonv-filter" },
    { mime = "application/oasis.opendocument.*", run = "office-textonv-filter" },
    { mime = "application/vnd.openxmlformats-officedocument.*", run = "office-textonv-filter" },
    { mime = "application/ms-*", run = "office-textonv-filter" },
    { mime = "application/msword", run = "office-textonv-filter" },
]

prepend_previewers = [
    # Office Documents
    { mime = "application/openxmlformats-officedocument.*", run = "office-textonv-filter" },
    { mime = "application/oasis.opendocument.*", run = "office-textonv-filter" },
    { mime = "application/vnd.openxmlformats-officedocument.*", run = "office-textonv-filter" },
    { mime = "application/ms-*", run = "office-textonv-filter" },
    { mime = "application/msword", run = "office-textonv-filter" },
]

{{- else if (and (lookPath "libreoffice") (lookPath "pdftoppm") (exec "sh" "-c" "ya pkg list | grep 'macydnah/office'") ) }}
[plugin]

prepend_preloaders = [
    # Office Documents
    { mime = "application/openxmlformats-officedocument.*", run = "office" },
    { mime = "application/oasis.opendocument.*", run = "office" },
    { mime = "application/vnd.openxmlformats-officedocument.*", run = "office" },
    { mime = "application/ms-*", run = "office" },
    { mime = "application/msword", run = "office" },
]

prepend_previewers = [
    # Office Documents
    { mime = "application/openxmlformats-officedocument.*", run = "office" },
    { mime = "application/oasis.opendocument.*", run = "office" },
    { mime = "application/vnd.openxmlformats-officedocument.*", run = "office" },
    { mime = "application/ms-*", run = "office" },
    { mime = "application/msword", run = "office" },
]
{{- end }}
